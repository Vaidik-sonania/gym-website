# ============================================================
# IronEdge Fitness — Environment Variables Template
# ============================================================
# This file is a TEMPLATE only. Do NOT put real keys here.
# Copy these key names into Replit Secrets (the lock icon
# in the left sidebar) and paste your real values there.
# ============================================================


# ------------------------------------------------------------
# CONTACT FORM (choose one)
# ------------------------------------------------------------

# Option A: Formspree
# Sign up at https://formspree.io → Create Form → copy endpoint
FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Option B: EmailJS
# Sign up at https://emailjs.com → Email Services → copy these
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key


# ------------------------------------------------------------
# PAYMENTS — RAZORPAY (recommended for India, ₹ payments)
# ------------------------------------------------------------
# Sign up at https://razorpay.com
# Go to Settings → API Keys → Generate Key
#
# SAFE to use in frontend code (identifies your account):
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
#
# SECRET — only used on backend, never in frontend code:
RAZORPAY_KEY_SECRET=your_secret_key_here


# ------------------------------------------------------------
# PAYMENTS — STRIPE (alternative, international)
# ------------------------------------------------------------
# Sign up at https://stripe.com → Developers → API Keys
#
# SAFE to use in frontend code:
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXX
#
# SECRET — only used on backend, never in frontend code:
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXX


# ------------------------------------------------------------
# OWNER NOTIFICATION EMAIL
# ------------------------------------------------------------
# Your email address — where purchase alerts get sent
OWNER_EMAIL=your@email.com
